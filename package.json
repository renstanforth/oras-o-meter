{
  "name": "orasometer",
  "type": "module",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "icons": "node scripts/generate-extension-icons.mjs",
    "predev": "npm run icons",
    "dev": "vite",
    "prebuild": "npm run icons",
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "zip": "node scripts/zip-dist.mjs",
