    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.304",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "archiver": "^7.0.1",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.7.3",
    "vite": "^6.2.2",
    "vue-tsc": "^2.2.8"
  }
}
